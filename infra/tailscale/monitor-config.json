{
  "Services": {
    "__TS_MONITOR_SERVICE__": {
      "TCP": {
        "443": {
          "HTTP": true
        },
        "80": {
          "HTTP": true
        }
      },
      "Web": {
        "__TS_MONITOR_DOMAIN__:443": {
          "Handlers": {
            "/": {
              "Proxy": "http://localhost:__MONITOR_PORT__"
            }
          }
        },
        "__TS_MONITOR_DOMAIN__:80": {
          "Handlers": {
            "/": {
              "Proxy": "http://localhost:__MONITOR_PORT__"
            }
          }
        }
      }
    }
  }
}
