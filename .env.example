# =============================================================================
# NEUROMANCERS Network — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# Production secrets are stored in Bitwarden Secrets Manager and injected
# at deploy-time. This file documents all required and optional variables.
# =============================================================================


# === Django Core =============================================================

DJANGO_SETTINGS_MODULE=config.settings.local
# django-environ reads .env when this is True
# DJANGO_READ_DOT_ENV_FILE=True
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_ADMIN_URL=admin/
DJANGO_ALLOWED_HOSTS=.localhost,127.0.0.1,0.0.0.0
# Set to True for local development, False in production
DJANGO_DEBUG=True
DJANGO_SECURE_SSL_REDIRECT=False
# Comma-separated list of CORS allowed origins
# DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8000
# Comma-separated list of trusted CSRF origins
# CSRF_TRUSTED_ORIGINS=http://localhost:8000


# === Database (PostgreSQL) ===================================================

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=neuromancers_network
POSTGRES_USER=change-me
POSTGRES_PASSWORD=change-me
# Constructed automatically by the entrypoint:
#   DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}


# === Redis ===================================================================

REDIS_URL=redis://redis:6379/0


# === Celery ==================================================================

# Flower credentials
CELERY_FLOWER_USER=change-me
CELERY_FLOWER_PASSWORD=change-me


# === AWS / S3 (django-storages) ==============================================

DJANGO_AWS_ACCESS_KEY_ID=
DJANGO_AWS_SECRET_ACCESS_KEY=
DJANGO_AWS_STORAGE_BUCKET_NAME=
DJANGO_AWS_S3_REGION_NAME=
DJANGO_AWS_S3_ENDPOINT_URL=
DJANGO_AWS_S3_ADDRESSING_STYLE=
DJANGO_AWS_S3_CUSTOM_DOMAIN=


# === AWS / S3 (backup scripts — used by infra/scripts/backup.sh) =============

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_ENDPOINT_URL_S3=
RETENTION_DAYS=30


# === Email ===================================================================

DJANGO_SERVER_EMAIL=
# If using django-anymail with a specific backend:
# ANYMAIL_MAILGUN_API_KEY=
# ANYMAIL_SENDGRID_API_KEY=


# === Sentry ==================================================================

SENTRY_DSN=


# === Security ================================================================

# Rate limiting, account registration
DJANGO_ACCOUNT_ALLOW_REGISTRATION=True


# === Gunicorn ================================================================

WEB_CONCURRENCY=4


# === Docker / Local Dev ======================================================

# Set to "yes" when running inside Docker (used by settings/local.py)
# USE_DOCKER=yes


# === Deployment (Coolify) ====================================================

# Bitwarden Secrets Manager access token — the only secret stored in Coolify
# BWS_ACCESS_TOKEN=
# Docker image tag to deploy (set automatically by Ansible per environment)
# DOCKER_TAG=latest
